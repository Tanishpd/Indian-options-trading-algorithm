# Copy to secrets/broker.env (git-ignored) and fill in. Never commit real values.
#
#   mkdir -p secrets && chmod 700 secrets
#   cp config/broker.env.example secrets/broker.env && chmod 600 secrets/broker.env
#
# From https://smartapi.angelbroking.com -> My Apps (create a Market Data app):
SMARTAPI_KEY=your_api_key_here
# Your Angel One login (client) code:
SMARTAPI_CLIENT_CODE=A123456
# Your login PIN:
SMARTAPI_PIN=0000
# TOTP secret: SmartAPI portal -> Enable TOTP -> copy the SECRET shown under the
# QR code (a base32 string), NOT the 6-digit code itself:
SMARTAPI_TOTP_SECRET=BASE32SECRETHERE
